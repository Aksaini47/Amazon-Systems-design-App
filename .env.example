# Amazon Systems Design — master secrets template
# Copy to `.env` and fill values. NEVER commit `.env`.
#
# Quick start:
#   1. copy .env.example .env
#   2. Fill sections below (Sir fills credentials)
#   3. powershell -File scripts\sync_env.ps1
#   4. cd agent && scripts\quick_setup.bat

# ─── GitHub (gh CLI, clone, CI) ─────────────────────────────────────────
GITHUB_USERNAME=
GITHUB_TOKEN=
GITHUB_PAT=

# ─── Mahika agent (synced to agent/.env) ───────────────────────────────
MAHIKA_STORAGE_ROOT=C:/Projects/Amazon Systems Design/data/mahika
MAHIKA_MODE=shadow

# Postgres — Oracle Cloud VM (see agent/scripts/setup_oracle_vm.md)
MAHIKA_DB_HOST=
MAHIKA_DB_PORT=5432
MAHIKA_DB_NAME=mahika
MAHIKA_DB_USER=mahika
MAHIKA_DB_PASSWORD=

# Amazon SP-API (see agent/scripts/sp_api_registration_checklist.md)
MAHIKA_SP_API_REFRESH_TOKEN=
MAHIKA_SP_API_LWA_CLIENT_ID=
MAHIKA_SP_API_LWA_CLIENT_SECRET=
MAHIKA_SP_API_ROLE_ARN=
MAHIKA_SP_API_REGION=eu-west-1
MAHIKA_SP_API_MARKETPLACE_ID=A21TJRUUN4KGV

# ─── Amazon Seller Central (synced to agent/.env for seller-login) ───────
AMAZON_SELLER_EMAIL=
AMAZON_SELLER_PASSWORD=
# Account owner — Develop Apps / SP-API setup (optional; keep separate from sub-user)
AMAZON_ADMIN_EMAIL=
AMAZON_ADMIN_PASSWORD=

# Telegram — OTP auto-fill (see agent/scripts/OTP_SETUP.md)
MAHIKA_TELEGRAM_BOT_TOKEN=
MAHIKA_TELEGRAM_CHAT_ID=

# Cockpit dashboard login token — generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
MAHIKA_COCKPIT_TOKEN=
MAHIKA_COCKPIT_PORT=8765

# Optional
MAHIKA_RUNNER_ID=
MAHIKA_SENTRY_DSN=

# ─── Legacy camera backend (backend/.env) ──────────────────────────────
BACKEND_STORAGE_ROOT=C:/Projects/Amazon Systems Design/data/mahika
BACKEND_PORT=3001
BACKEND_AMAZON_CLIENT_ID=
BACKEND_AMAZON_CLIENT_SECRET=
BACKEND_AMAZON_REFRESH_TOKEN=
BACKEND_AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV

# ─── Cursor / Claude (optional — BYOK) ─────────────────────────────────
ANTHROPIC_API_KEY=
