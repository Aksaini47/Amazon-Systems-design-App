# ──────────────────────────────────────────────────────────────────────
# RepairFully Backend — Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (same folder) and edit the values below.
# The server reads `.env` on startup via dotenv.

# ─── STORAGE ROOT ─────────────────────────────────────────────────────
# All session data lands here, organized per order:
#   {STORAGE_ROOT}/orders/{orderId}/
#     {orderId}_PK.mp4 (or _RT.mp4)
#     {orderId}_PK_front.jpg, _back.jpg, _label.jpg, etc.
#     {orderId}_meta.json
#
# Use a fast drive (NVMe) for best upload throughput. Forward slashes work
# on Windows too (or escape backslashes: D:\\RepairFullyData).
#
# Examples:
#   STORAGE_ROOT=D:/RepairFullyData                # Windows NVMe
#   STORAGE_ROOT=/mnt/data/repairfully             # Linux
#   STORAGE_ROOT=./data                            # default: relative to backend folder
STORAGE_ROOT=./data

# ─── SERVER ───────────────────────────────────────────────────────────
PORT=3001

# ─── AMAZON SP-API (optional — skip if not syncing orders from Amazon) ─
# Register at: https://developer.amazonservices.com
AMAZON_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AMAZON_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AMAZON_REFRESH_TOKEN=Atzr|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV  # India marketplace ID

# ─── LEGACY (still honored if STORAGE_ROOT not set; will be removed) ──
# VIDEOS_DIR=./videos
# IMAGES_DIR=./images
