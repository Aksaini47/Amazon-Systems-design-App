# ─── Mahika agent environment configuration ──────────────────────────────
# Copy this file to `.env` (gitignored) and fill in your values.
# Sir's actual `.env` lives on the NVMe at the project root — NEVER commit it.

# ─── Postgres on Oracle Cloud Always Free VM ────────────────────────────
# Fill in after Oracle VM provisioned via scripts/setup_oracle_vm.md
MAHIKA_DB_HOST=oracle-vm-public-ip
MAHIKA_DB_PORT=5432
MAHIKA_DB_NAME=mahika
MAHIKA_DB_USER=mahika
MAHIKA_DB_PASSWORD=                  # set during postgres install

# Local dev override — point at local Postgres while building Phase 3/4.
# Comment out for production use.
# MAHIKA_DB_HOST=localhost

# ─── Storage paths ──────────────────────────────────────────────────────
# Root of the NVMe-mounted folder hierarchy. Set per machine in env file
# since the NVMe drive letter varies (D:/, E:/, F:/ depending on what's
# plugged into the laptop).
MAHIKA_STORAGE_ROOT=D:/Mahika
# Subdirs created by scripts/setup_nvme_folders.py:
#   {root}/orders/                 — from mobile camera app sync
#   {root}/sync_inbox/             — mobile drops files here, agent moves to orders
#   {root}/processed/              — orders with composite generated + claim filed
#   {root}/backups/                — daily Postgres snapshots
#   {root}/logs/                   — structured agent logs

# ─── Amazon SP-API credentials ──────────────────────────────────────────
# Obtained after SP-API developer registration (see scripts/sp_api_registration_checklist.md).
# Sir's friend's account credentials go here for now; future support
# for Sir's reactivated account adds a second credential set.
MAHIKA_SP_API_REFRESH_TOKEN=
MAHIKA_SP_API_LWA_CLIENT_ID=
MAHIKA_SP_API_LWA_CLIENT_SECRET=
MAHIKA_SP_API_ROLE_ARN=              # optional — only if using role-based auth
MAHIKA_SP_API_REGION=eu-west-1       # for Amazon.in: EU region per SP-API docs
MAHIKA_SP_API_MARKETPLACE_ID=A21TJRUUN4KGV  # India marketplace

# ─── Telegram bot (alerts) ──────────────────────────────────────────────
# Create via @BotFather on Telegram → get the token.
# Get chat_id by messaging the bot once + calling getUpdates.
MAHIKA_TELEGRAM_BOT_TOKEN=
MAHIKA_TELEGRAM_CHAT_ID=

# ─── Runner identity ────────────────────────────────────────────────────
# Auto-detected from hostname if unset. Override to differentiate Dell vs
# ThinkPad in audit logs.
MAHIKA_RUNNER_ID=

# ─── Operating mode ─────────────────────────────────────────────────────
# 'shadow' — log decisions but do not file claims (default during Phase 7a)
# 'live'   — autonomous filing for whitelisted scenarios (Phase 7b+)
# 'manual' — per-action approval required (debugging / risky scenario)
MAHIKA_MODE=shadow

# ─── Crashlytics-equivalent for the agent (optional) ────────────────────
# Sentry DSN for Python exception tracking. Leave blank to disable.
MAHIKA_SENTRY_DSN=
