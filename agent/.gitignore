# Mahika agent — gitignore

# Environment (secrets — NEVER commit)
.env
.env.local

# Python
__pycache__/
*.py[cod]
*.so
.venv/
venv/
env/
.eggs/
*.egg-info/
build/
dist/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# OS / IDE
.DS_Store
.vscode/
.idea/

# NVMe runtime markers (per-machine)
.mahika_runner_marker

# Logs (rotated; never tracked)
logs/
*.log

# Local Postgres backups (huge)
backups/
*.dump
*.sql.gz

# Graphify outputs (knowledge graph artefacts, regenerable)
graphify-out/
